    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\n\nif (!row.Applicant_cv || !row.assigned_job_offer_id) {\n  throw new Error(`Missing CV or Job URL for candidate: ${row.name}`);\n}\n\nfunction extractDriveId(url) {\n  const match = url.match(/[-\\w]{25,}/);\n  return match ? match[0] : url;\n}\n\nreturn [{\n  json: {\n    cv_id: extractDriveId(row.Applicant_cv),\n    job_id: extractDriveId(row.assigned_job_offer_id),\n    candidate_name: row.name,\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -352,
        -160
      ],
      "id": "917ffe6a-84d4-4326-a427-d3ee26875c4a",
