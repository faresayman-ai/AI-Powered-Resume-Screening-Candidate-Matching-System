    {
      "parameters": {
        "promptType": "define",
        "text": "=You are acting as a strict job recruiter.\n\nYour task is to decide if the candidate is truly qualified for the job by comparing the CV with the Job Description.\n\nRules:\n\n* Carefully compare the candidate's skills, experience, tools, education, and responsibilities with the job requirements.\n* The candidate should be marked **Accepted** ONLY if the CV clearly shows most of the required skills and relevant experience.\n* If important required skills, qualifications, or relevant experience are missing, return **Not Qualified**.\n* Do NOT assume skills that are not explicitly written in the CV.\n* If the match is weak, partial, or unclear, return **Not Qualified**.\n* Only return **Error** if the CV or Job Description is missing or empty.\n\nCV:\n{{ $json['CV text'] }}\n\nJob Description:\n{{ $json['Job Text'] }}\n\nReturn ONLY one of these words exactly:\nAccepted\nNot Qualified\nError\n",
        "batching": {}
      },
